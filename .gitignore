# pipenv
#   According to pypa/pipenv#1185, it is recommended to check in Pipfile.lock.
#   However, in case of a library, things are a bit different.
#   For more information, see https://pipenv.pypa.io/en/latest/advanced/#pipfile-vs-setup-py
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to check in poetry.lock.
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
#poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to check in pdm.lock.
#   https://pdm.fming.dev/#use-pdm-in-a-project
.pdm.toml
.pdm-python
pdm.lock
.pdm-plugins/

# PEP 582; used by e.g. github.com/frenzyryz/venvpdm
__pypackages__/

